<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.TaskParticipantMapper">

    <resultMap type="com.ruoyi.system.domain.TaskParticipant" id="TaskParticipantResult">
        <id     property="id"         column="id"         />
        <result property="taskId"     column="task_id"    />
        <result property="userId"     column="user_id"    />
        <result property="userName"   column="user_name"  />
        <result property="nickName"   column="nick_name"  />
        <result property="status"     column="status"     />
        <result property="joinTime"   column="join_time"  />
        <result property="createdAt"  column="created_at" />
    </resultMap>

    <sql id="selectVo">
        SELECT tp.id, tp.task_id, tp.user_id, tp.status, tp.join_time, tp.created_at,
               u.user_name, u.nick_name
        FROM task_participant tp
        LEFT JOIN sys_user u ON tp.user_id = u.user_id
    </sql>

    <select id="selectByTaskId" resultMap="TaskParticipantResult">
        <include refid="selectVo"/> WHERE tp.task_id = #{taskId} ORDER BY tp.join_time
    </select>

    <select id="selectByTaskAndUser" resultMap="TaskParticipantResult">
        <include refid="selectVo"/> WHERE tp.task_id = #{taskId} AND tp.user_id = #{userId}
    </select>

    <select id="selectTaskIdsByUserId" resultType="Long">
        SELECT tp.task_id FROM task_participant tp WHERE tp.user_id = #{userId}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO task_participant (task_id, user_id, status, join_time, created_at)
        VALUES (#{taskId}, #{userId}, #{status}, NOW(), NOW())
    </insert>

    <delete id="deleteById">
        DELETE FROM task_participant WHERE id = #{id}
    </delete>

    <delete id="deleteByTaskAndUser">
        DELETE FROM task_participant WHERE task_id = #{taskId} AND user_id = #{userId}
    </delete>

    <delete id="deleteByTaskId">
        DELETE FROM task_participant WHERE task_id = #{taskId}
    </delete>

    <update id="updateStatus">
        UPDATE task_participant SET status = #{status} WHERE id = #{id}
    </update>

    <select id="countByTaskAndStatus" resultType="int">
        SELECT COUNT(1) FROM task_participant WHERE task_id = #{taskId} AND status = #{status}
    </select>

</mapper>
